{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5269",
      "https://localhost:7016"
    ]
  },
  "Jwt": {
    "Issuer": "Hermes",
    "Audience": "Hermes.Api",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3308;Database=hermes;User=root;Password=password1234!;"
  },
  "HermesSite": {
    "PublicBaseUrl": "https://hermes.de",
    "SupportEmail": "support@hermes.de"
  }
}
