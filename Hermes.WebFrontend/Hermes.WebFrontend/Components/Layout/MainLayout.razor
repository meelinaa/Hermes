@inherits LayoutComponentBase

<div class="page page-fullwidth">
    <main>
        <div class="top-row px-4">
            <a class="hermes-main-brand" href="/">Hermes</a>
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" rel="noopener noreferrer">About</a>
        </div>

        <article class="content px-4">
