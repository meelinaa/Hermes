@using System.Net.Http.Json
@using System.Text.Json
@using Hermes.Domain.Entities
@using Hermes.Domain.Enums
@using Hermes.WebFrontend.Client.Services
@inject HttpClient Http
@inject AuthTokenStore AuthTokens
@inject NewsSubscriptionListCache NewsListCache

<div class="news-settings-panel">
    @if (!showForm)
    {
        <div class="news-settings-toolbar">
            <button type="button" class="news-settings-add" @onclick="StartCreate" aria-label="Neue News-Einstellung" title="Neue News-Einstellung">
                <span aria-hidden="true">+</span>
            </button>
        </div>

        @if (loading)
        {
            <p class="news-settings-muted">Lade Konfigurationen…</p>
        }
        else if (!string.IsNullOrEmpty(loadError))
        {
            <p class="user-profile-feedback" role="alert">@loadError</p>
        }
        else if (items.Count == 0)
        {
            <p class="news-settings-muted">Noch keine News-Konfiguration. Tippe auf <strong>+</strong>, um eine anzulegen.</p>
        }
        else
        {
            <ul class="news-settings-list">
                @foreach (var n in items.OrderBy(x => x.Id))
                {
                    <li class="news-settings-card">
                        <div class="news-settings-card-head">
                            <h3 class="news-settings-card-title">@TitleFor(n)</h3>
                            <div class="news-settings-card-actions">
                                <button type="button" class="news-settings-icon news-settings-icon--danger" title="Löschen"
                                        disabled="@deletingId.HasValue" @onclick="() => DeleteAsync(n)">
                                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M9 3v1H4v2h1v13a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V6h1V4h-5V3H9m0 5h2v9H9V8m4 0h2v9h-2V8Z"/></svg>
                                </button>
                                <button type="button" class="news-settings-icon news-settings-icon--primary" title="Bearbeiten"
                                        @onclick="() => StartEdit(n)">
                                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25M20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83Z"/></svg>
                                </button>
                            </div>
                        </div>
                        <dl class="news-settings-dl">
                            <div><dt>Schlagworte</dt><dd>@FormatKeywords(n)</dd></div>
                            <div><dt>Kategorien</dt><dd>@FormatCategories(n)</dd></div>
                            <div><dt>Sprachen</dt><dd>@FormatLanguages(n)</dd></div>
                            <div><dt>Länder</dt><dd>@FormatCountries(n)</dd></div>
                            <div><dt>Sende-Tage</dt><dd>@FormatWeekdays(n)</dd></div>
                            <div><dt>Sende-Zeitpunkt</dt><dd>@FormatTimes(n)</dd></div>
                        </dl>
                    </li>
                }
            </ul>
        }
    }
    else
    {
        <NewsSubscriptionCard InitialModel="editModel"
                              ShowBackButton="true"
                              OnReturnToList="HandleReturnFromForm" />
    }
</div>

@code {
    private List<News> items = new();
    private bool showForm;
    private News? editModel;
    private bool loading = true;
    private string? loadError;
    private int? deletingId;

    protected override async Task OnInitializedAsync() => await LoadListAsync(forceReload: false).ConfigureAwait(false);

    private async Task LoadListAsync(bool forceReload)
    {
        loading = true;
        loadError = null;
        await AuthTokens.EnsureLoadedFromStorageAsync().ConfigureAwait(false);
        var userId = JwtPayloadDisplayName.TryGetUserId(AuthTokens.AccessToken);
        if (userId is null)
        {
            loadError = "Bitte erneut anmelden.";
            items = new List<News>();
            loading = false;
            return;
        }

        var (loaded, err) = await NewsListCache.GetOrLoadAsync(userId.Value, Http, forceReload).ConfigureAwait(false);
        items = loaded;
        loadError = err;
        loading = false;
    }

    private void StartCreate()
    {
        editModel = null;
        showForm = true;
    }

    private void StartEdit(News n)
    {
        editModel = n;
        showForm = true;
    }

    private async Task HandleReturnFromForm(bool listChanged)
    {
        showForm = false;
        editModel = null;
        if (listChanged)
        {
            NewsListCache.Invalidate();
            await LoadListAsync(forceReload: true).ConfigureAwait(false);
        }
    }

    private async Task DeleteAsync(News n)
    {
        await AuthTokens.EnsureLoadedFromStorageAsync().ConfigureAwait(false);
        var userId = JwtPayloadDisplayName.TryGetUserId(AuthTokens.AccessToken);
        if (userId is null)
            return;

        deletingId = n.Id;
        try
        {
            var response = await Http.DeleteAsync(
                $"api/v1/users/news/userId={userId.Value}/newsId={n.Id}").ConfigureAwait(false);
            if (response.IsSuccessStatusCode)
            {
                NewsListCache.Invalidate();
                await LoadListAsync(forceReload: true).ConfigureAwait(false);
            }
            else
                loadError = await ReadErrorDetailAsync(response).ConfigureAwait(false);
        }
        finally
        {
            deletingId = null;
        }
    }

    private static string TitleFor(News n) =>
        n.Keywords is { Count: > 0 } ? string.Join(", ", n.Keywords) : "Ohne Schlagworte";

    private static string FormatKeywords(News n) =>
        n.Keywords is { Count: > 0 } ? string.Join(", ", n.Keywords) : "—";

    private static string FormatCategories(News n) =>
        n.Category is { Count: > 0 }
            ? string.Join(", ", n.Category.OrderBy(c => c.ToString()).Select(c => NewsEnumGermanDisplay.CategoryDe(c)))
            : "—";

    private static string FormatLanguages(News n) =>
        n.Languages is { Count: > 0 }
            ? string.Join(", ", n.Languages.OrderBy(l => l.ToString()).Select(l => NewsEnumGermanDisplay.LanguageDe(l)))
            : "—";

    private static string FormatCountries(News n) =>
        n.Countries is { Count: > 0 }
            ? string.Join(", ", n.Countries.OrderBy(c => c.ToString()).Select(c => NewsEnumGermanDisplay.CountryDe(c)))
            : "—";

    private static string FormatWeekdays(News n) =>
        n.SendOnWeekdays.Count > 0
            ? string.Join(", ", n.SendOnWeekdays.OrderBy(d => (int)d).Select(ShortWeekday))
            : "—";

    private static string ShortWeekday(Weekdays d) => d switch
    {
        Weekdays.Monday => "Mo",
        Weekdays.Tuesday => "Di",
        Weekdays.Wednesday => "Mi",
        Weekdays.Thursday => "Do",
        Weekdays.Friday => "Fr",
        Weekdays.Saturday => "Sa",
        Weekdays.Sunday => "So",
        _ => d.ToString()
    };

    private static string FormatTimes(News n) =>
        n.SendAtTimes.Count > 0
            ? string.Join(", ", n.SendAtTimes.OrderBy(t => t).Select(t => t.ToString("HH:mm")))
            : "—";

    private static async Task<string> ReadErrorDetailAsync(HttpResponseMessage response)
    {
        try
        {
            using var stream = await response.Content.ReadAsStreamAsync().ConfigureAwait(false);
            using var doc = await JsonDocument.ParseAsync(stream).ConfigureAwait(false);
            if (doc.RootElement.TryGetProperty("detail", out var d) && d.ValueKind == JsonValueKind.String)
                return d.GetString() ?? $"Fehler ({(int)response.StatusCode}).";
        }
        catch
        {
            // ignore
        }

        return $"Anfrage fehlgeschlagen ({(int)response.StatusCode}).";
    }
}
