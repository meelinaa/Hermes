@implements IDisposable
@inject AuthTokenStore Tokens
@inject AuthSessionService Session
@inject NavigationManager Navigation

@code {
    protected override void OnInitialized() =>
        Navigation.LocationChanged += OnLocationChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await TryRedirectAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) =>
        _ = InvokeAsync(TryRedirectAsync);

    private async Task TryRedirectAsync()
    {
        try
        {
            await Session.EnsureSessionAsync();
        }
        catch
        {
            try
            {
                await Tokens.ClearAsync();
            }
            catch
            {
                // ignore secondary failures
            }

            return;
        }

        if (!string.IsNullOrEmpty(Tokens.AccessToken))
            return;

        var path = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        if (path.Length == 0)
            path = "/";

        if (IsPublic(path))
            return;

        Navigation.NavigateTo("/login", forceLoad: false, replace: true);
    }

    private static bool IsPublic(string path) =>
        path.Equals("/", StringComparison.OrdinalIgnoreCase) ||
        path.Equals("/login", StringComparison.OrdinalIgnoreCase) ||
        path.Equals("/register", StringComparison.OrdinalIgnoreCase) ||
        path.Equals("/Error", StringComparison.OrdinalIgnoreCase);

    public void Dispose() =>
        Navigation.LocationChanged -= OnLocationChanged;
}
