@page "/user-settings"
@layout AppHomeLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using System.Threading
@using Hermes.Domain
@using Hermes.Domain.DTOs
@using Hermes.WebFrontend.Client.Services
@using Hermes.WebFrontend.Client.Services.Auth
@using Hermes.WebFrontend.Client.Services.User
@implements IAsyncDisposable
@inject AuthTokenStore AuthTokens
@inject HttpClient Http
@inject UserProfileRefreshNotifier ProfileRefresh

<PageTitle>Profil — Hermes</PageTitle>

<div class="home-content @((showVerificationModal ? " home-content--modal-open" : ""))">
    <h2 class="home-welcome">Profil &amp; Sicherheit</h2>

    <section class="home-panel user-profile-panel">
        <h3 class="user-profile-title">Persönliche Daten und Sicherheit</h3>

        <div class="user-profile-field">
            <label class="user-profile-label" for="pf-name">Name</label>
            <div class="user-profile-input-wrap">
                <span class="user-profile-input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5Zm0 2c-4.42 0-8 1.79-8 4v2h16v-2c0-2.21-3.58-4-8-4Z"/></svg>
                </span>
                <input id="pf-name" class="user-profile-input" type="text" autocomplete="name"
                       placeholder="Name" @bind="profileName" @bind:event="oninput" />
            </div>
        </div>

        <div class="user-profile-field">
            <div class="user-profile-label-row">
                <label class="user-profile-label" for="pf-email">E-Mail</label>
                @if (profileEmailVerified)
                {
                    <span class="user-profile-email-badge user-profile-email-badge--verified">Verifiziert</span>
                }
                else
                {
                    <span class="user-profile-email-badge user-profile-email-badge--unverified">Nicht verifiziert</span>
                }
            </div>
            <div class="user-profile-input-wrap">
                <span class="user-profile-input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5L4 8V6l8 5 8-5v2z"/></svg>
                </span>
                <input id="pf-email" class="user-profile-input" type="email" autocomplete="email"
                       placeholder="email@example.com" @bind="profileEmail" @bind:event="oninput" />
            </div>
        </div>

        @if (!profileEmailVerified)
        {
            <div class="user-profile-verify-warning" role="status">
                <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M12 2 1 21h22L12 2zm0 3.99L19.53 19H4.47L12 5.99zM11 16v2h2v-2h-2zm0-6v4h2v-4h-2z"/></svg>
                <span>Ihre E-Mail ist nicht verifiziert. Daher können keine Newsletter oder Sicherheitsbenachrichtigungen gesendet werden.</span>
            </div>

            <button type="button" class="user-profile-verify-btn--cta" @onclick="OpenEmailVerificationModalAsync"
                    disabled="@(modalOpenBusy || string.IsNullOrWhiteSpace(profileEmail))">
                @(modalOpenBusy ? "Wird geöffnet…" : "E-Mail verifizieren")
            </button>
        }

        <div class="user-profile-field user-profile-field--after-verify">
            <label class="user-profile-label" for="pf-old-pw">Altes Passwort</label>
            <div class="user-profile-input-wrap">
                <span class="user-profile-input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2Zm-6 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"/></svg>
                </span>
                <input id="pf-old-pw" class="user-profile-input" type="@(showOldPassword ? "text" : "password")" autocomplete="off"
                       readonly="@oldPasswordReadonly"
                       aria-invalid="@(!string.IsNullOrEmpty(oldPasswordFieldError))"
                       aria-describedby="@(string.IsNullOrEmpty(oldPasswordFieldError) ? null : "pf-old-pw-err")"
                       @onfocus="OnOldPasswordFocus"
                       @bind="oldPassword" @bind:event="oninput" />
                <button type="button" class="user-profile-input-reveal"
                        @onclick="() => showOldPassword = !showOldPassword"
                        aria-pressed="@(showOldPassword ? "true" : "false")"
                        aria-label="@(showOldPassword ? "Passwort verbergen" : "Passwort anzeigen")">
                    @if (showOldPassword)
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/></svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
                    }
                </button>
            </div>
            @if (!string.IsNullOrEmpty(oldPasswordFieldError))
            {
                <p id="pf-old-pw-err" class="user-profile-field-error" role="alert">@oldPasswordFieldError</p>
            }
        </div>

        <div class="user-profile-field">
            <label class="user-profile-label" for="pf-new-pw">Neues Passwort</label>
            <div class="user-profile-input-wrap">
                <span class="user-profile-input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2Zm-6 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"/></svg>
                </span>
                <input id="pf-new-pw" class="user-profile-input" type="@(showNewPassword ? "text" : "password")" autocomplete="new-password"
                       @bind="newPassword" @bind:event="oninput" />
                <button type="button" class="user-profile-input-reveal"
                        @onclick="() => showNewPassword = !showNewPassword"
                        aria-pressed="@(showNewPassword ? "true" : "false")"
                        aria-label="@(showNewPassword ? "Passwort verbergen" : "Passwort anzeigen")">
                    @if (showNewPassword)
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/></svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
                    }
                </button>
            </div>
            @if (newPassword.Length > 0)
            {
                <ul class="hermes-reg-rules user-profile-new-pw-rules" aria-label="Passwortanforderungen">
                    <li class="@RuleClass(PasswordLenOk)">mind. 8 Zeichen</li>
                    <li class="@RuleClass(PasswordCaseOk)">Groß- und Kleinbuchstaben</li>
                    <li class="@RuleClass(PasswordDigitOk)">mindestens eine Zahl</li>
                    <li class="@RuleClass(PasswordSymbolOk)">mindestens ein Symbol</li>
                </ul>
            }
        </div>

        @if (!string.IsNullOrEmpty(profileFeedback))
        {
            <p class="user-profile-feedback" role="status">@profileFeedback</p>
        }

        <div class="user-profile-actions">
            <button type="button"
                    class="@ProfileSubmitButtonClass"
                    disabled="@profileBusy"
                    aria-busy="@profileBusy"
                    aria-disabled="@ProfileSubmitAriaDisabled"
                    @onclick="OnUpdateProfile">
                @(profileBusy ? "Speichern…" : "Profil aktualisieren")
            </button>
        </div>
    </section>
</div>

@if (showVerificationModal)
{
    <div class="verify-email-overlay" role="dialog" aria-modal="true" aria-labelledby="verify-email-dialog-title">
        <div class="verify-email-overlay__backdrop" aria-hidden="true"></div>
        <div class="verify-email-overlay__dialog" @onclick:stopPropagation>
            <h3 id="verify-email-dialog-title" class="verify-email-dialog__title">E-Mail-Verifizierung</h3>

            <label class="verify-email-dialog__label" for="verify-code-input">Verifizierungscode eingeben</label>
            <div class="user-profile-input-wrap">
                <span class="user-profile-input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
                </span>
                <input id="verify-code-input" class="user-profile-input" type="text" inputmode="numeric" autocomplete="one-time-code" maxlength="12"
                       placeholder="Code aus E-Mail einfügen…" @bind="verificationCodeInput" @bind:event="oninput" />
            </div>

            <button type="button" class="verify-email-dialog__confirm" @onclick="OnConfirmVerificationCodeAsync" disabled="@confirmCodeBusy">
                @(confirmCodeBusy ? "Wird geprüft…" : "Code bestätigen")
            </button>

            @if (!string.IsNullOrEmpty(verificationCodeError))
            {
                <p class="verify-email-dialog__code-feedback" role="alert">@verificationCodeError</p>
            }

            <div class="verify-email-dialog__info">
                <div>
                    <strong>E-Mail noch nicht angekommen?</strong>
                    Falls die E-Mail nicht nach einigen Minuten angekommen ist, können Sie eine neue anfordern.
                </div>
                <div style="margin-top:0.65rem;">
                    @if (resendCooldownSecondsRemaining > 0)
                    {
                        <span class="verify-email-dialog__resend-link" aria-disabled="true">Neue E-Mail anfordern (verfügbar in @FormatMmSs(resendCooldownSecondsRemaining))</span>
                    }
                    else
                    {
                        <button type="button" class="verify-email-dialog__resend-link" @onclick="OnResendVerificationEmailAsync">Neue E-Mail anfordern</button>
                    }
                </div>
            </div>

            <button type="button" class="verify-email-dialog__send-secondary"
                    disabled="@(resendCooldownSecondsRemaining > 0 || modalSendBusy)"
                    @onclick="OnResendVerificationEmailAsync">
                @(modalSendBusy ? "Wird gesendet…" : "E-Mail senden")
            </button>
            @if (resendCooldownSecondsRemaining > 0)
            {
                <p class="verify-email-dialog__wait">Bitte warten… @FormatMmSs(resendCooldownSecondsRemaining)</p>
            }

            @if (!string.IsNullOrEmpty(verificationSendError))
            {
                <p class="verify-email-dialog__feedback" role="alert">@verificationSendError</p>
            }
        </div>
    </div>
}

@code {
    private const int ResendCooldownTotalSeconds = 180;

    private const string WrongOrExpiredCodeMessage =
        "Der eingegebene Code ist nicht richtig oder nicht mehr gültig. Bitte prüfen Sie den Code und versuchen Sie es erneut. " +
        "Wenn der Code abgelaufen ist oder weiterhin nicht funktioniert, können Sie nach Ablauf der Wartezeit unten eine neue Verifizierungs-E-Mail anfordern.";

    private string profileName = string.Empty;
    private string profileEmail = string.Empty;
    private bool profileEmailVerified;

    private string _oldPassword = string.Empty;

    private string oldPassword
    {
        get => _oldPassword;
        set
        {
            var v = value ?? string.Empty;
            if (string.Equals(_oldPassword, v, StringComparison.Ordinal))
                return;
            _oldPassword = v;
            oldPasswordFieldError = null;
        }
    }

    private string? oldPasswordFieldError;
    private string newPassword = string.Empty;
    private bool showOldPassword;
    private bool showNewPassword;
    private bool oldPasswordReadonly = true;
    private bool profileBusy;
    private string? profileFeedback;
    private int? profileUserId;

    private bool PasswordLenOk => newPassword.Length >= 8;

    private bool PasswordCaseOk =>
        newPassword.Any(char.IsUpper) && newPassword.Any(char.IsLower);

    private bool PasswordDigitOk => newPassword.Any(char.IsDigit);

    private bool PasswordSymbolOk =>
        newPassword.Any(static c => char.IsPunctuation(c) || char.IsSymbol(c));

    /// <summary>When user typed a new password, all four rules must pass (same as registration).</summary>
    private bool NewPasswordRulesSatisfied =>
        PasswordLenOk && PasswordCaseOk && PasswordDigitOk && PasswordSymbolOk;

    /// <summary>True if the user intends to change the password (non-whitespace new password field).</summary>
    private bool IsAttemptingPasswordChange => !string.IsNullOrWhiteSpace(newPassword);

    /// <summary>Profile can be saved: required fields set; if changing password, old password + rule checks.</summary>
    private bool CanSaveProfile =>
        profileUserId is not null
        && !profileBusy
        && !string.IsNullOrWhiteSpace(profileName)
        && !string.IsNullOrWhiteSpace(profileEmail)
        && (!IsAttemptingPasswordChange
            || (!string.IsNullOrWhiteSpace(oldPassword) && NewPasswordRulesSatisfied));

    /// <summary>Visual „disabled“ while form is invalid; button stays clickable so we can show guidance.</summary>
    private bool ProfileSubmitLooksInactive => !CanSaveProfile && !profileBusy;

    private string ProfileSubmitButtonClass =>
        "user-profile-submit" + (ProfileSubmitLooksInactive ? " user-profile-submit--inactive" : string.Empty);

    private bool ProfileSubmitAriaDisabled => ProfileSubmitLooksInactive || profileBusy;

    private static string RuleClass(bool ok) =>
        ok ? "hermes-reg-rule hermes-reg-rule--ok" : "hermes-reg-rule";

    private bool showVerificationModal;
    private bool modalOpenBusy;
    private bool modalSendBusy;
    private bool confirmCodeBusy;
    private string verificationCodeInput = string.Empty;
    private string? verificationCodeError;
    private string? verificationSendError;
    private int resendCooldownSecondsRemaining;
    private Timer? _resendCooldownTimer;

    private static string FormatMmSs(int totalSeconds)
    {
        var m = totalSeconds / 60;
        var s = totalSeconds % 60;
        return string.Create(CultureInfo.InvariantCulture, $"{m}:{s:D2}");
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthTokens.EnsureLoadedFromStorageAsync().ConfigureAwait(false);

        var userId = JwtPayloadDisplayName.TryGetUserId(AuthTokens.AccessToken);
        if (userId is null)
        {
            profileFeedback = "Benutzer konnte nicht ermittelt werden. Bitte erneut anmelden.";
            return;
        }

        profileUserId = userId.Value;
        await LoadProfileFromApiAsync().ConfigureAwait(false);
    }

    public async ValueTask DisposeAsync()
    {
        StopResendCooldownTimer();
        await Task.CompletedTask.ConfigureAwait(false);
    }

    private async Task LoadProfileFromApiAsync()
    {
        if (profileUserId is null)
            return;

        try
        {
            var response = await Http.GetAsync($"api/v1/users/{profileUserId.Value}").ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                profileFeedback = await ReadErrorDetailAsync(response).ConfigureAwait(false);
                return;
            }

            var scope = await response.Content.ReadFromJsonAsync<UserScope>(JsonSerializerOptions.Web).ConfigureAwait(false);
            if (scope is not null)
            {
                profileName = scope.Name ?? string.Empty;
                profileEmail = scope.Email ?? string.Empty;
                profileEmailVerified = scope.IsEmailVerified;
            }
        }
        catch (Exception ex)
        {
            profileFeedback = $"Profil konnte nicht geladen werden: {ex.Message}";
        }
    }

    private readonly record struct ProblemRead(string? Type, string? Title, string? Detail);

    private static async Task<ProblemRead> TryReadProblemAsync(HttpResponseMessage response)
    {
        try
        {
            using var stream = await response.Content.ReadAsStreamAsync().ConfigureAwait(false);
            using var doc = await JsonDocument.ParseAsync(stream).ConfigureAwait(false);
            var root = doc.RootElement;
            string? type = null;
            string? title = null;
            string? detail = null;
            if (root.TryGetProperty("type", out var ty) && ty.ValueKind == JsonValueKind.String)
                type = ty.GetString();
            if (root.TryGetProperty("title", out var ti) && ti.ValueKind == JsonValueKind.String)
                title = ti.GetString();
            if (root.TryGetProperty("detail", out var d) && d.ValueKind == JsonValueKind.String)
                detail = d.GetString();
            return new ProblemRead(type, title, detail);
        }
        catch
        {
            return new ProblemRead(null, null, null);
        }
    }

    private static string ProblemUserMessage(ProblemRead p, HttpResponseMessage response)
    {
        if (!string.IsNullOrWhiteSpace(p.Detail))
            return p.Detail!;
        if (!string.IsNullOrWhiteSpace(p.Title))
            return p.Title!;
        return $"Anfrage fehlgeschlagen ({(int)response.StatusCode}).";
    }

    private static async Task<string> ReadErrorDetailAsync(HttpResponseMessage response)
    {
        try
        {
            using var stream = await response.Content.ReadAsStreamAsync().ConfigureAwait(false);
            using var doc = await JsonDocument.ParseAsync(stream).ConfigureAwait(false);
            var root = doc.RootElement;
            if (root.TryGetProperty("detail", out var d) && d.ValueKind == JsonValueKind.String)
            {
                var ds = d.GetString();
                if (!string.IsNullOrWhiteSpace(ds))
                    return ds!;
            }
            if (root.TryGetProperty("title", out var t) && t.ValueKind == JsonValueKind.String)
            {
                var ts = t.GetString();
                if (!string.IsNullOrWhiteSpace(ts))
                    return ts!;
            }
        }
        catch
        {
            // ignore
        }

        return $"Anfrage fehlgeschlagen ({(int)response.StatusCode}).";
    }

    private void OnOldPasswordFocus()
    {
        if (!oldPasswordReadonly)
            return;
        oldPasswordReadonly = false;
    }

    private void StopResendCooldownTimer()
    {
        _resendCooldownTimer?.Dispose();
        _resendCooldownTimer = null;
    }

    private void ArmResendCooldownTimer()
    {
        StopResendCooldownTimer();
        _resendCooldownTimer = new Timer(
            _ => _ = InvokeAsync(TickResendCooldownAsync),
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(1));
    }

    private Task TickResendCooldownAsync()
    {
        if (!showVerificationModal)
        {
            StopResendCooldownTimer();
            return Task.CompletedTask;
        }

        if (resendCooldownSecondsRemaining > 0)
            resendCooldownSecondsRemaining--;

        if (resendCooldownSecondsRemaining <= 0)
            StopResendCooldownTimer();

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OpenEmailVerificationModalAsync()
    {
        profileFeedback = null;
        verificationCodeError = null;
        verificationSendError = null;
        verificationCodeInput = string.Empty;

        if (profileUserId is null)
        {
            profileFeedback = "Benutzer konnte nicht ermittelt werden. Bitte erneut anmelden.";
            return;
        }

        if (string.IsNullOrWhiteSpace(profileEmail))
        {
            profileFeedback = "Bitte zuerst eine E-Mail-Adresse eintragen.";
            return;
        }

        modalOpenBusy = true;
        showVerificationModal = true;
        StopResendCooldownTimer();
        resendCooldownSecondsRemaining = 0;
        StateHasChanged();

        try
        {
            var ok = await SendVerificationEmailAsync().ConfigureAwait(false);
            if (ok)
            {
                resendCooldownSecondsRemaining = ResendCooldownTotalSeconds;
                ArmResendCooldownTimer();
            }
        }
        finally
        {
            modalOpenBusy = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task OnResendVerificationEmailAsync()
    {
        if (resendCooldownSecondsRemaining > 0 || modalSendBusy || !showVerificationModal)
            return;

        verificationSendError = null;
        verificationCodeError = null;
        modalSendBusy = true;
        StateHasChanged();
        try
        {
            var ok = await SendVerificationEmailAsync().ConfigureAwait(false);
            if (ok)
            {
                resendCooldownSecondsRemaining = ResendCooldownTotalSeconds;
                ArmResendCooldownTimer();
            }
        }
        finally
        {
            modalSendBusy = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task<bool> SendVerificationEmailAsync()
    {
        if (profileUserId is null)
        {
            verificationSendError = "Benutzer konnte nicht ermittelt werden.";
            return false;
        }

        var email = profileEmail.Trim();
        if (string.IsNullOrWhiteSpace(email))
        {
            verificationSendError = "Bitte eine E-Mail-Adresse eintragen.";
            return false;
        }

        try
        {
            var encoded = Uri.EscapeDataString(email);
            var response = await Http.GetAsync($"api/v1/users/verify/{encoded}").ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                verificationSendError = await ReadErrorDetailAsync(response).ConfigureAwait(false);
                return false;
            }

            verificationSendError = null;
            return true;
        }
        catch (Exception ex)
        {
            verificationSendError = $"E-Mail konnte nicht angefordert werden: {ex.Message}";
            return false;
        }
    }

    private async Task OnConfirmVerificationCodeAsync()
    {
        verificationCodeError = null;
        if (profileUserId is null)
        {
            verificationCodeError = "Benutzer konnte nicht ermittelt werden.";
            return;
        }

        var digits = new string((verificationCodeInput ?? string.Empty).Where(char.IsDigit).ToArray());
        if (digits.Length is < 6 or > 6 || !int.TryParse(digits, NumberStyles.None, CultureInfo.InvariantCulture, out var code))
        {
            verificationCodeError =
                "Bitte geben Sie den sechsstelligen Code aus der E-Mail ein. Achten Sie auf alle Ziffern; Sie können es danach erneut versuchen oder eine neue E-Mail anfordern.";
            return;
        }

        confirmCodeBusy = true;
        StateHasChanged();
        try
        {
            var body = new { userId = profileUserId.Value, code };
            var response = await Http.PostAsJsonAsync("api/v1/users/verify/code", body, JsonSerializerOptions.Web).ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                if ((int)response.StatusCode == 400)
                    verificationCodeError = WrongOrExpiredCodeMessage;
                else
                    verificationCodeError = await ReadErrorDetailAsync(response).ConfigureAwait(false);
                return;
            }

            verificationCodeError = null;
            StopResendCooldownTimer();
            resendCooldownSecondsRemaining = 0;
            showVerificationModal = false;
            verificationCodeInput = string.Empty;
            await LoadProfileFromApiAsync().ConfigureAwait(false);
            if (string.IsNullOrEmpty(profileFeedback))
                profileFeedback = "E-Mail-Adresse wurde verifiziert.";
            await ProfileRefresh.NotifyAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            verificationCodeError = $"Verifizierung fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            confirmCodeBusy = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task OnUpdateProfile()
    {
        profileFeedback = null;
        oldPasswordFieldError = null;
        if (profileUserId is null)
        {
            profileFeedback = "Benutzer konnte nicht ermittelt werden. Bitte erneut anmelden.";
            return;
        }

        if (string.IsNullOrWhiteSpace(profileName) || string.IsNullOrWhiteSpace(profileEmail))
        {
            profileFeedback = "Name und E-Mail dürfen nicht leer sein.";
            return;
        }

        var newPw = string.IsNullOrWhiteSpace(newPassword) ? null : newPassword;
        var curPw = string.IsNullOrWhiteSpace(oldPassword) ? null : oldPassword;
        if (newPw is not null && curPw is null)
        {
            profileFeedback = "Bitte das aktuelle Passwort eingeben, wenn du ein neues Passwort setzen möchtest.";
            return;
        }

        if (newPw is not null && !(PasswordLenOk && PasswordCaseOk && PasswordDigitOk && PasswordSymbolOk))
        {
            profileFeedback =
                "Das neue Passwort erfüllt nicht alle Anforderungen: mindestens 8 Zeichen, Groß- und Kleinbuchstaben, mindestens eine Zahl und ein Symbol. Bitte korrigieren Sie das Passwort oder leeren Sie das Feld „Neues Passwort“, um nur Profildaten zu speichern.";
            return;
        }

        profileBusy = true;
        try
        {
            var body = new
            {
                id = profileUserId.Value,
                name = profileName.Trim(),
                email = profileEmail.Trim(),
                newPassword = newPw,
                currentPassword = curPw
            };

            var response = await Http.PutAsJsonAsync("api/v1/users", body, JsonSerializerOptions.Web).ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                var problem = await TryReadProblemAsync(response).ConfigureAwait(false);
                var msg = ProblemUserMessage(problem, response);
                if (newPw is not null
                    && string.Equals(problem.Type, HermesProblemTypes.WrongCurrentPassword, StringComparison.Ordinal))
                {
                    oldPasswordFieldError = msg;
                    profileFeedback = null;
                }
                else
                {
                    oldPasswordFieldError = null;
                    profileFeedback = msg;
                }

                return;
            }

            oldPassword = string.Empty;
            newPassword = string.Empty;
            showOldPassword = false;
            showNewPassword = false;
            oldPasswordReadonly = true;

            profileFeedback = null;
            await LoadProfileFromApiAsync().ConfigureAwait(false);
            if (string.IsNullOrEmpty(profileFeedback))
                profileFeedback = "Profil gespeichert.";
            await ProfileRefresh.NotifyAsync().ConfigureAwait(false);
            await InvokeAsync(StateHasChanged);
        }
        catch (HttpRequestException ex)
        {
            profileFeedback = $"Verbindung fehlgeschlagen: {ex.Message}";
        }
        catch (Exception ex)
        {
            profileFeedback = $"Speichern fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            profileBusy = false;
        }
    }
}
