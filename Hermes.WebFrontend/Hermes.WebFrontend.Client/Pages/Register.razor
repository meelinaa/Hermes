@page "/register"
@layout AuthLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using System.Text.Json
@using Hermes.Application.Models
@using Hermes.Domain.Entities
@using Hermes.WebFrontend.Client.Components.Auth
@using Hermes.WebFrontend.Client.Model
@using Hermes.WebFrontend.Client.Services.Auth
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthTokenStore TokenStore

<PageTitle>Registrieren — Hermes</PageTitle>

<div class="auth-split">
    <div class="auth-split__left">
        <div class="hermes-auth-card">
            <div class="hermes-auth-brand-row">
                <HermesBrand />
            </div>
            <h1 class="hermes-auth-title">Registrieren</h1>
            <p class="hermes-auth-subtitle">Neues Konto für Hermes anlegen.</p>

            <div class="hermes-auth-fields">
                <div class="hermes-auth-field">
                    <label class="hermes-auth-label" for="reg-username">Benutzername</label>
                    <input id="reg-username" class="hermes-auth-input" type="text" autocomplete="username"
                           placeholder="Benutzername" @bind="username" @bind:event="oninput" />
                </div>
                <div class="hermes-auth-field">
                    <label class="hermes-auth-label" for="reg-email">E-Mail</label>
                    <input id="reg-email" class="hermes-auth-input" type="email" autocomplete="email"
                           placeholder="name@beispiel.de" @bind="email" @bind:event="oninput" />
                    @if (ShowEmailFormatError)
                    {
                        <p class="hermes-reg-hint hermes-reg-hint--error" role="status">Bitte eine gültige E-Mail-Adresse eingeben.</p>
                    }
                </div>
                <div class="hermes-auth-field">
                    <label class="hermes-auth-label" for="reg-password">Passwort</label>
                    <input id="reg-password" class="hermes-auth-input" type="password" autocomplete="new-password"
                           placeholder="Passwort" @bind="password" @bind:event="oninput" />
                    @if (password.Length > 0)
                    {
                        <ul class="hermes-reg-rules" aria-label="Passwortanforderungen">
                            <li class="@RuleClass(PasswordLenOk)">mind. 8 Zeichen</li>
                            <li class="@RuleClass(PasswordCaseOk)">Groß- und Kleinbuchstaben</li>
                            <li class="@RuleClass(PasswordDigitOk)">mindestens eine Zahl</li>
                            <li class="@RuleClass(PasswordSymbolOk)">mindestens ein Symbol</li>
                        </ul>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(registerError))
            {
                <p class="hermes-auth-error" role="alert">@registerError</p>
            }

            <button type="button" class="hermes-auth-submit" disabled="@(!CanRegister || isBusy)" @onclick="RegisterAsync">Registrieren</button>

            <p class="hermes-auth-footer mt-4 mb-0">
                <a href="/login">Zurück zur Anmeldung</a>
            </p>
        </div>
    </div>
    <AuthSwissPoster />
</div>

@code {
    private static readonly EmailAddressAttribute EmailValidator = new();

    private string username = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string? registerError;
    private bool isBusy;

    private bool PasswordLenOk => password.Length >= 8;

    private bool PasswordCaseOk =>
        password.Any(char.IsUpper) && password.Any(char.IsLower);

    private bool PasswordDigitOk => password.Any(char.IsDigit);

    private bool PasswordSymbolOk =>
        password.Any(static c => char.IsPunctuation(c) || char.IsSymbol(c));

    /// <summary>All registration password rules satisfied (independent of username/e-mail).</summary>
    private bool PasswordRulesSatisfied =>
        PasswordLenOk && PasswordCaseOk && PasswordDigitOk && PasswordSymbolOk;

    private bool EmailFormatOk =>
        !string.IsNullOrWhiteSpace(email) && EmailValidator.IsValid(email.Trim());

    private bool ShowEmailFormatError =>
        !string.IsNullOrWhiteSpace(email) && !EmailFormatOk;

    private bool CanRegister =>
        !string.IsNullOrWhiteSpace(username)
        && EmailFormatOk
        && PasswordRulesSatisfied;

    private static string RuleClass(bool ok) =>
        ok ? "hermes-reg-rule hermes-reg-rule--ok" : "hermes-reg-rule";

    protected override async Task OnInitializedAsync()
    {
        await TokenStore.EnsureLoadedFromStorageAsync();
        if (!string.IsNullOrEmpty(TokenStore.AccessToken))
            Nav.NavigateTo("/home", forceLoad: false, replace: true);
    }

    private async Task RegisterAsync()
    {
        registerError = null;
        if (!CanRegister || isBusy)
            return;

        isBusy = true;
        try
        {
            var newUser = new User
            {
                Id = 0,
                Name = username.Trim(),
                Email = email.Trim(),
                PasswordHash = password,
                IsEmailVerified = false
            };

            var regResponse = await Http.PostAsJsonAsync("api/v1/users", newUser, JsonSerializerOptions.Web).ConfigureAwait(false);
            if (!regResponse.IsSuccessStatusCode)
            {
                registerError = await ReadApiErrorAsync(regResponse).ConfigureAwait(false);
                return;
            }

            var loginResponse = await Http.PostAsJsonAsync(
                    "api/v1/auth/login",
                    new LoginRequest { NameOrEmail = email.Trim(), Password = password },
                    JsonSerializerOptions.Web)
                .ConfigureAwait(false);

            if (!loginResponse.IsSuccessStatusCode)
            {
                registerError = await ReadApiErrorAsync(loginResponse).ConfigureAwait(false)
                    ?? "Konto wurde angelegt; automatische Anmeldung ist fehlgeschlagen. Bitte auf der Anmeldeseite einloggen.";
                return;
            }

            var authBody = await loginResponse.Content.ReadFromJsonAsync<AuthLoginResponse>(JsonSerializerOptions.Web).ConfigureAwait(false);
            if (authBody is null || string.IsNullOrEmpty(authBody.AccessToken) || string.IsNullOrEmpty(authBody.RefreshToken))
            {
                registerError = "Konto angelegt; unerwartete Antwort beim Anmelden.";
                return;
            }

            await TokenStore.PersistAsync(authBody.AccessToken, authBody.RefreshToken).ConfigureAwait(false);
            Nav.NavigateTo("/home");
        }
        catch (HttpRequestException ex)
        {
            registerError = $"Verbindung zur API fehlgeschlagen. Läuft die API und stimmt ApiBaseUrl? ({ex.Message})";
        }
        catch (Exception ex)
        {
            registerError = $"Registrierung fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private static async Task<string?> ReadApiErrorAsync(HttpResponseMessage response)
    {
        try
        {
            using var stream = await response.Content.ReadAsStreamAsync().ConfigureAwait(false);
            using var doc = await JsonDocument.ParseAsync(stream).ConfigureAwait(false);
            if (doc.RootElement.TryGetProperty("detail", out var d) && d.ValueKind == JsonValueKind.String)
                return d.GetString();
            if (doc.RootElement.TryGetProperty("title", out var t) && t.ValueKind == JsonValueKind.String)
                return t.GetString();
        }
        catch
        {
            // ignore parse errors
        }

        return response.StatusCode switch
        {
            System.Net.HttpStatusCode.Conflict => "Diese E-Mail ist bereits registriert.",
            System.Net.HttpStatusCode.BadRequest => "Ungültige Daten.",
            System.Net.HttpStatusCode.Unauthorized => "Anmeldung nach Registrierung fehlgeschlagen.",
            _ => $"Anfrage fehlgeschlagen ({(int)response.StatusCode}).",
        };
    }
}
